    {"id": "e3", "fromNode": "average_meter_class", "fromSide": "bottom", "toNode": "am_init", "toSide": "top"},
    {"id": "e4", "fromNode": "am_init", "fromSide": "bottom", "toNode": "am_reset", "toSide": "top"},
    {"id": "e5", "fromNode": "am_reset", "fromSide": "bottom", "toNode": "am_update", "toSide": "top"},
    {"id": "e6", "fromNode": "accuracy_func", "fromSide": "bottom", "toNode": "accuracy_detail", "toSide": "top"},
    {"id": "e7", "fromNode": "accuracy_detail", "fromSide": "bottom", "toNode": "topk_explain", "toSide": "top"}
  ]
}
