    {"id": "e4", "fromNode": "load_checkpoint", "fromSide": "bottom", "toNode": "load_detail", "toSide": "top"},
    {"id": "e5", "fromNode": "save_detail", "fromSide": "bottom", "toNode": "two_files", "toSide": "top"},
    {"id": "e6", "fromNode": "load_detail", "fromSide": "bottom", "toNode": "why_checkpoint", "toSide": "top"}
  ]
}
